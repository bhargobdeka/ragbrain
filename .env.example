# ============================================================
# RAGBrain Configuration
# Copy this file to .env and fill in your values.
# Only ANTHROPIC_API_KEY is required to get started.
# ============================================================

# ---- LLM (required) ----------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ---- LLM Model Settings ------------------------------------
# Default Claude model to use for generation, grading, and rewriting
RAGBRAIN_LLM_MODEL=claude-sonnet-4-6
# Model for lightweight tasks (grading, rewriting) to save cost
RAGBRAIN_LLM_FAST_MODEL=claude-3-5-haiku-20241022

# ---- Embeddings (local, no API key needed) ------------------
# HuggingFace model name for dense embeddings
RAGBRAIN_EMBEDDING_MODEL=all-mpnet-base-v2
# HuggingFace cross-encoder model for reranking
RAGBRAIN_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---- Qdrant Vector Store -----------------------------------
# Mode: "local" (no Docker, data stored on disk) or "server" (Docker / Qdrant Cloud)
RAGBRAIN_QDRANT_MODE=local
# Path for local mode (created automatically)
# IMPORTANT: Do NOT place inside Dropbox/OneDrive/iCloud — the lock file conflicts.
RAGBRAIN_QDRANT_LOCAL_PATH=~/.ragbrain/qdrant
# URL for server mode only (ignored in local mode)
RAGBRAIN_QDRANT_URL=http://localhost:6333
# Optional: Qdrant API key (only needed for Qdrant Cloud)
RAGBRAIN_QDRANT_API_KEY=

# ---- Qdrant Collection Settings ----------------------------
# Default collection/namespace (used when no user_id is provided)
RAGBRAIN_QDRANT_COLLECTION=ragbrain_default
# Vector dimensions for all-mpnet-base-v2
RAGBRAIN_EMBEDDING_DIM=768

# ---- Retrieval Settings ------------------------------------
# Number of candidates from dense + sparse search each
RAGBRAIN_RETRIEVAL_TOP_K=20
# Number of results after reranking
RAGBRAIN_RERANK_TOP_N=5
# Cosine similarity threshold for deduplication (0.0-1.0)
RAGBRAIN_DEDUP_THRESHOLD=0.85
# Relevance score cutoff for article filtering (1-10 scale)
RAGBRAIN_MIN_RELEVANCE_SCORE=6

# ---- Agentic RAG Settings ----------------------------------
# Maximum query rewrite retries in CRAG loop
RAGBRAIN_MAX_RETRIES=2
# Maximum hallucination-check retries
RAGBRAIN_MAX_HALLUCINATION_RETRIES=2

# ---- Telegram Bot (optional, for delivery) -----------------
# Get from @BotFather on Telegram
RAGBRAIN_TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (send /start to your bot, then check logs)
RAGBRAIN_TELEGRAM_CHAT_ID=

# ---- Slack (optional legacy — not required for RSS + Telegram daily flow) --
# Bot OAuth Token from api.slack.com/apps (starts with xoxb-)
RAGBRAIN_SLACK_BOT_TOKEN=
# Channel/DM ID where AI news arrives (starts with C or D)
RAGBRAIN_SLACK_CHANNEL_ID=
# Channel to post architecture review results (defaults to same channel)
RAGBRAIN_SLACK_POST_CHANNEL_ID=
# How many hours back to scan for news
RAGBRAIN_SLACK_LOOKBACK_HOURS=24

# ---- Article Pipeline Settings -----------------------------
# Comma-separated list of RSS feed URLs to monitor
RAGBRAIN_RSS_FEEDS_STR=https://example.substack.com/feed,https://medium.com/feed/@username
# How many hours back to look for new articles
RAGBRAIN_ARTICLE_LOOKBACK_HOURS=24
# Cron for morning digest (default: 8:00 AM)
RAGBRAIN_MORNING_CRON=0 8 * * *
# Cron for evening jobs that use this time (book lesson if enabled, arch snapshot when automation on)
RAGBRAIN_EVENING_CRON=0 19 * * *
# Evening Telegram book lesson (default: off — use morning digest + automation for news)
# RAGBRAIN_EVENING_BOOK_LESSON_ENABLED=true

# ---- Book Pipeline Settings --------------------------------
# Path to folder where you drop PDF books for ingestion
RAGBRAIN_INBOX_DIR=./inbox
# JSON file tracking daily lesson progress per book
RAGBRAIN_BOOK_STATE_FILE=./data/book_state.json

# ---- User Interests (for relevance scoring) ----------------
# Comma-separated topics; used to score article relevance
RAGBRAIN_INTERESTS_STR=RAG systems,LLM agents,machine learning,data science,RLHF

# ---- Suppress tokenizer parallelism warning (safe to enable) ----
TOKENIZERS_PARALLELISM=false

# ---- Optional: OpenAI (alternative LLM provider) -----------
# OPENAI_API_KEY=your-openai-api-key-here
# RAGBRAIN_LLM_PROVIDER=openai
# RAGBRAIN_LLM_MODEL=gpt-4o
